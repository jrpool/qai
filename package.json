{
  "name": "qai",
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run hint && npm run lint && npm test",
    "hint": "htmlhint public/*.html",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "start": "node --env-file=.env src/main.ts",
    "test": "c8 --check-coverage --clean node --test",
    "typecheck": "tsc --strict"
  },
  "dependencies": {},
  "devDependencies": {
    "c8": "*",
    "eslint": "*",
    "htmlhint": "*",
    "node-html-parser": "*",
    "@stylistic/eslint-plugin": "*",
    "typescript": "*",
    "@typescript-eslint/parser": "*",
    "@types/node": "*"
  },
  "c8": {
    "lines": 99,
    "functions": 99,
    "branches": 99,
    "statements": 99
  }
}
